# =============================================================================
# docker_open_claw — copy to .env and fill in your values
#   make env          create .env from this file (skips if .env exists)
#   make env-force    overwrite .env from this file
# =============================================================================

# --- Gemini (required) -------------------------------------------------------
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Primary model (google/ prefix required for Gemini)
OPENCLAW_MODEL=google/gemini-2.5-pro

# --- OpenClaw gateway --------------------------------------------------------
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan

# Set at least one auth method (generate a random string for local use)
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=change-me

# Timezone for calendar skills and logs
TZ=America/Los_Angeles

# --- Persistent paths (host → container) -------------------------------------
OPENCLAW_CONFIG_DIR=./data
OPENCLAW_WORKSPACE_DIR=./data/workspace

# --- WhatsApp ----------------------------------------------------------------
WHATSAPP_ENABLED=true
# Comma-separated E.164 numbers — synced to openclaw.json by make sync-config
WHATSAPP_ALLOW_FROM=+15551234567

# --- SMS via Twilio (optional — leave blank to disable) ----------------------
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_ALLOW_FROM=

# --- Google Workspace (gog skill) — use a DEDICATED bot Gmail, not personal ---
# Full guide: docs/google-workspace.md
GOG_ACCOUNT=yourname-openclaw@gmail.com
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=

# OAuth client JSON → make google-credentials SRC=/path/to/client_secret.json
# (stored at data/google/credentials.json, mounted into the container)

# Legacy / optional — gog uses credentials.json; keep blank unless templating
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Flight research (optional) ----------------------------------------------
FLIGHT_API_PROVIDER=
FLIGHT_API_KEY=
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# --- Docker image (override to pin a version) --------------------------------
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
